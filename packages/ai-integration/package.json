{
  "name": "@sqlhelper/ai-integration",
  "version": "0.1.0",
  "description": "AI integration for SQL generation, query explanation, and code assistance",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "openai": "^4.75.1",
    "@anthropic-ai/sdk": "^0.31.0",
    "@azure/openai": "^2.0.0",
    "@sqlhelper/database-core": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsup": "^8.3.5"
  }
}
