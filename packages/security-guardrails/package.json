{
  "name": "@sqlhelper/security-guardrails",
  "version": "0.1.0",
  "description": "Security guardrails for AI-generated SQL queries",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest"
  },
  "dependencies": {
    "@sqlhelper/database-core": "workspace:*",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "typescript": "^5.3.3",
    "tsup": "^8.0.1",
    "vitest": "^1.0.4"
  },
  "keywords": [
    "sql",
    "security",
    "guardrails",
    "audit",
    "safety"
  ],
  "author": "SQLHelper",
  "license": "MIT"
}
