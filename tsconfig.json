{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "paths": {
      "@sqlhelper/*": [
        "./packages/*/src"
      ],
      "@app/*": [
        "./apps/*/src"
      ]
    },
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage"
  ],
  "references": [
    {
      "path": "./apps/desktop"
    },
    {
      "path": "./apps/renderer"
    },
    {
      "path": "./packages/database-core"
    },
    {
      "path": "./packages/storage"
    },
    {
      "path": "./packages/ai-integration"
    },
    {
      "path": "./packages/security-guardrails"
    }
  ]
}
