# Email provider (Resend)
RESEND_API_KEY=
EMAIL_FROM=downloads@lucedata.com
# Optional: friendly sender name, e.g. "LuceData Beta"
EMAIL_FROM_NAME=
DOWNLOAD_REQUESTS_EMAIL=it@kovimatic.ie

# Direct download URLs (e.g., public cloud storage links)
NEXT_PUBLIC_DOWNLOAD_URL_MAC_ARM64=
NEXT_PUBLIC_DOWNLOAD_URL_MAC_X64=
NEXT_PUBLIC_DOWNLOAD_URL_WINDOWS=

# Site base URL for links inside emails (optional, defaults to https://lucedata.com)
SITE_URL=

# Optional: email branding
# Absolute URL to a logo used in the email header
LOGO_URL=
# Custom footer line
EMAIL_FOOTER_TEXT=
